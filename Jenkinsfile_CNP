#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET")
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  env.UNIT_TESTS_COMMAND = "yarn test:unit && yarn test:coverage && yarn lint && yarn test:routes && yarn test:a11y"
  
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  // Setup for Smoke Tests (Jest-based, no Playwright needed)
  before('tests') {
    sh 'rm -rf smoke-output functional-output a11y-output allure-results'
  }

  // Setup for Functional Tests - Install Playwright before tests run
  before('functionalTests') {
    sh 'npx playwright install chromium --with-deps'
  }

  // Run Playwright A11y tests only if functional tests passed
  afterSuccess('functionalTests') {
    echo "Functional tests passed. Running Playwright Accessibility Tests..."
    // Playwright already installed from functional tests
    yarnBuilder.yarn('test:a11y:report')
  }

  afterAlways('smokeTest') {
    junit testResults: 'smoke-output/*.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/**, pods-logs-smoke/**', allowEmptyArchive: true
    fingerprint 'pods-logs-smoke/**/*.log, jest-smoke-test-report.html'
  }

  afterAlways('functionalTests') {
    junit testResults: 'functional-output/*.xml, a11y-output/*.xml', allowEmptyResults: true
    
    archiveArtifacts artifacts: 'functional-output/**, a11y-output/**, pods-logs-functional/**', allowEmptyArchive: true

    fingerprint 'pods-logs-functional/**/*.log, functional-output/playwright-functional-report/index.html, a11y-output/playwright-accessibility-report/index.html'

    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [
        [path: 'functional-output/allure-results'],
        [path: 'a11y-output/allure-results']
      ]
    ])
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.JENKINS_BRANCH = "master"
  }

  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}