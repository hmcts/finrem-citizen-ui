#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET")
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  env.UNIT_TESTS_COMMAND = "yarn test:unit && yarn test:coverage && yarn lint && yarn test:routes && yarn test:a11y"
  
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  before('tests') {
    sh 'rm -rf smoke-output functional-output allure-results allure-results-smoke allure-results-a11y'
    sh 'yarn playwright install chromium --with-deps'
  }

  // --- FUNCTIONAL TESTS ---
  before('functionalTests') {
    sh 'mkdir -p functional-output allure-results allure-results-a11y'
    env.TEST_RESULTS_DIR = "functional-output"
    env.FUNCTIONAL_TESTS_COMMAND = "yarn test:functional"
  }

  // --- ACCESSIBILITY & FUNCTIONAL REPORTING ---
  afterAlways('functionalTests') {
    // We pass TEST_RESULTS_DIR here to ensure it aligns with the functional tests folder
    echo "Running accessibility tests with TEST_RESULTS_DIR set to ${env.TEST_RESULTS_DIR}"
    sh "REPORT_NAME=accessibility TEST_RESULTS_DIR=functional-output ALLURE_RESULTS_DIR=allure-results-a11y yarn test:playwright:a11y || true"
    
    // Renaming logic for BOTH reports and artifact processing
    sh '''
      echo "Processing report artifacts..."
      
      # Handle Functional Report (standard index.html to uniquely named html file)
      if [ -d functional-output/playwright-functional-test-report ]; then
        cp functional-output/playwright-functional-test-report/index.html functional-output/playwright-functional-test-report.html
      fi
      
      # Handle Accessibility Report
      if [ -d functional-output/playwright-accessibility-test-report ]; then
        cp functional-output/playwright-accessibility-test-report/index.html functional-output/playwright-accessibility-test-report.html
      fi
    '''

    // Look for JUnit XMLs in the functional-output root (where playwright.config.mts saves them)
    junit testResults: 'functional-output/*.xml', allowEmptyResults: true
    
    // Aggregate functional and a11y Allure results
    allure([
        includeProperties: false,
        jdk: '',
        properties: [],
        reportBuildPolicy: 'ALWAYS',
        results: [[path: 'allure-results'], [path: 'allure-results-a11y']]
    ])
    
    // Archive the output folder and the specific a11y allure results
    archiveArtifacts artifacts: 'functional-output/**, allure-results-a11y/**', allowEmptyArchive: true
  }

  afterAlways('smokeTest') {
    junit testResults: '**/smoke-output/*.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/**', allowEmptyArchive: true
    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results-smoke']]
    ])
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.JENKINS_BRANCH = "master"
  }

  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}