#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET")
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  env.UNIT_TESTS_COMMAND = "yarn test:unit && yarn test:coverage && yarn lint && yarn test:routes && yarn test:a11y"
  
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  before('tests') {
    // Clean up previous runs including loose files at root
    sh 'rm -rf smoke-output functional-output allure-results* test-results *.html *.xml'
    sh 'yarn playwright install chromium --with-deps'
  }

  before('functionalTest') {
    sh 'mkdir -p functional-output allure-results-functional allure-results-a11y'
    env.TEST_RESULTS_DIR = "functional-output"

    env.FUNCTIONAL_TESTS_CMD = """
      yarn test:functional; func_exit=\$?;
      yarn test:playwright:a11y; pw_exit=\$?;
      if [ \$func_exit -ne 0 ]; then
        exit \$func_exit
      fi
      exit \$pw_exit
    """
  }

  afterAlways('functionalTests') {
    echo "Processing Functional and Accessibility Reports..."
    
    sh '''
      # Move and Rename Functional Report to root (Loose)
      if [ -f "functional-output/playwright-functional-test-report/index.html" ]; then
        mv "functional-output/playwright-functional-test-report/index.html" "playwright-functional-report.html"
      fi

      # Move and Rename Accessibility Report to root (Loose)
      if [ -f "functional-output/playwright-accessibility-test-report/index.html" ]; then
        mv "functional-output/playwright-accessibility-test-report/index.html" "playwright-a11y-report.html"
      fi

      # Bring XMLs to root
      cp functional-output/junit-*.xml . || true
    '''

    junit testResults: 'functional-output/junit-*.xml', allowEmptyResults: true
    
    allure([
        includeProperties: false,
        jdk: '',
        properties: [],
        reportBuildPolicy: 'ALWAYS',
        results: [[path: 'allure-results-functional'], [path: 'allure-results-a11y']]
    ])
    
    // ARCHIVE FIX: Targets the loose files now at the root
    archiveArtifacts artifacts: '*.html, *.xml', allowEmptyArchive: true
  }

  afterAlways('smokeTest') {
    sh 'cp smoke-output/*.xml . || true'
    
    junit testResults: 'smoke-output/*.xml', allowEmptyResults: true
    
    // ARCHIVE FIX: Targets loose files
    archiveArtifacts artifacts: '*.html, *.xml', allowEmptyArchive: true

    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results-smoke']]
    ])
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() { env.JENKINS_BRANCH = "master" }
  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}