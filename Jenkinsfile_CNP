#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    // Use COS S2S secret - works for CCD API access
    secret("finrem-case-orchestration-service-s2s-key", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET"),
    // Caseworker credentials for case creation
    secret("fr-caseworker-username", "USERNAME_CASEWORKER"),
    secret("fr-caseworker-password", "PASSWORD_CASEWORKER"),
    // Solicitor credentials for case submission
    secret("playwright-solicitor-username", "PLAYWRIGHT_SOLICITOR_USERNAME"),
    secret("playwright-solicitor-password", "PLAYWRIGHT_SOLICITOR_PSWD"),
    // System user for citizen case lookup
    secret("finrem-system-update-username", "IDAM_SYSTEM_USERNAME"),
    secret("finrem-system-update-password", "IDAM_SYSTEM_PASSWORD")
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  // 1. Unit-level checks (Jest, Lint, Routes) into one stage
  env.UNIT_TESTS_COMMAND = "yarn test:unit && yarn test:coverage && yarn lint && yarn test:routes"
  
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }
  // 2. Setup for Smoke and Functional Tests
  before('tests') {
    sh 'rm -rf smoke-output functional-output a11y-output allure-results allure-results-smoke allure-results-a11y'
    sh 'npx playwright install --with-deps'
  }

  // 3. Setup for Functional Tests
  before('functionalTests') {
    env.FUNCTIONAL_TESTS_COMMAND = "test:functional"
  }

  afterAlways('smokeTest') {
    junit testResults: 'smoke-output/smoke-test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/**', allowEmptyArchive: true
    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results-smoke']]
    ])
  }

  afterAlways('functionalTests') {
     
      junit testResults: 'functional-output/functional-test-results.xml', allowEmptyResults: true
      allure([
          includeProperties: false,
          jdk: '',
          properties: [],
          reportBuildPolicy: 'ALWAYS',
          results: [[path: 'allure-results']]
      ])
      archiveArtifacts artifacts: 'functional-output/**', allowEmptyArchive: true
    }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.JENKINS_BRANCH = "master"
    env.RUNNING_ENV = "aat"
  }

  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.RUNNING_ENV = "pr-${CHANGE_ID}"
    env.TEST_URL = "https://finrem-citizen-ui-pr-${CHANGE_ID}.preview.platform.hmcts.net"
    env.CCD_DATA_STORE_API_URL = "https://ccd-data-store-api-aat.aat.platform.hmcts.net"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}