#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET")
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  env.UNIT_TESTS_COMMAND = "yarn test:unit && yarn test:coverage && yarn lint && yarn test:routes"
  
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  before('tests') {
    sh 'rm -rf smoke-output functional-output a11y-output allure-results allure-results-smoke'
    sh 'npx playwright install chromium --with-deps'
  }

  before('functionalTests') {
    echo "Running Functional Tests (with @PR tags)..."
    sh 'npx playwright install --with-deps'
    env.FUNCTIONAL_TESTS_COMMAND = "test:functional:report"
  }

  afterSuccess('functionalTests') {
    echo "Running Accessibility Tests..."
    sh 'npx playwright install --with-deps'
    sh 'yarn test:a11y:report'
  }

  afterAlways('smokeTest') {
    junit testResults: 'smoke-output/smoke--test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/jest-test-report.html,smoke-output/**', allowEmptyArchive: true
  }

  afterAlways('functionalTests') {
    junit testResults: 'functional-output/test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'functional-output/playwright-functional-test-report.html,functional-output/**', allowEmptyArchive: true
    
    junit testResults: 'a11y-output/test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'a11y-output/playwright-accessibility-test-report.html,a11y-output/**', allowEmptyArchive: true


    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [
        [path: 'functional-output/allure-results'],
        [path: 'a11y-output/allure-results']
      ]
    ])
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.JENKINS_BRANCH = "master"
  }

  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  } 
}