#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("idam-secret" ,"OAUTH2_CLIENT_FINREM"),
    secret("finrem-idam-client-secret", "FINREM_IDAM_CLIENT_SECRET"),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  loadVaultSecrets(secrets)

  // Define how to calculate the URL once to avoid repetition/bugs
  def getTargetUrl = {
    if (env.RUNNING_ENV == "aat") {
      return "https://manage-case.aat.platform.hmcts.net"
    } else {
      // Fallback for PRs or if RUNNING_ENV isn't set yet
      def prEnv = env.RUNNING_ENV ?: "pr-${env.CHANGE_ID}"
      return "https://finrem-citizen-ui-${prEnv}.preview.platform.hmcts.net"
    }
  }

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }
  
  before('tests') {
    sh 'rm -rf smoke-output functional-output allure-results allure-results-smoke'
  }

  // --- SMOKE TESTS ---
  before('smokeTest') {
    env.TEST_RESULTS_DIR = "smoke-output"
    env.ALLURE_RESULTS_DIR = "allure-results-smoke"
    
    env.TEST_URL = getTargetUrl()
    
    echo "Checking health for Smoke Tests: ${env.TEST_URL}"
    sh "timeout 300s bash -c 'until [ \"\$(curl -s -L -o /dev/null -w \"%{http_code}\" -k ${env.TEST_URL})\" -lt 400 ]; do echo \"Waiting for ${env.TEST_URL}... \"; sleep 10; done'"
    
    sh 'npx playwright install chromium --with-deps'
  }

  afterAlways('smokeTest') {
    junit testResults: 'smoke-output/functional-test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/**', allowEmptyArchive: true
    allure([results: [[path: 'allure-results-smoke']]])
  }

  // --- FUNCTIONAL TESTS ---
  before('functionalTests') {
    env.FUNCTIONAL_TESTS_COMMAND = "test:functional"
    env.TEST_RESULTS_DIR = "functional-output"
    env.ALLURE_RESULTS_DIR = "allure-results"
    
    env.TEST_URL = getTargetUrl()

    echo "Checking health for Functional Tests: ${env.TEST_URL}"
    sh "timeout 300s bash -c 'until [ \"\$(curl -s -L -o /dev/null -w \"%{http_code}\" -k ${env.TEST_URL})\" -lt 400 ]; do echo \"Waiting for ${env.TEST_URL}... \"; sleep 10; done'"
    
    sh 'npx playwright install chromium --with-deps'
  }

  afterSuccess('functionalTests') {
    yarnBuilder.yarn('test:a11y')
  }

  afterAlways('functionalTests') {
     junit testResults: 'functional-output/functional-test-results.xml', allowEmptyResults: true
     allure([results: [[path: 'allure-results']]])
     archiveArtifacts artifacts: 'functional-output/**', allowEmptyArchive: true
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.RUNNING_ENV = "aat"
  }

  onPR() {
    env.RUNNING_ENV = "pr-${env.CHANGE_ID}" 
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}