#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("idam-secret" ,"OAUTH2_CLIENT_FINREM"),
    secret("finrem-idam-client-secret", "FINREM_IDAM_CLIENT_SECRET"),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  loadVaultSecrets(secrets)

  // Set the Playwright path once globally for all stages
  env.PLAYWRIGHT_BROWSERS_PATH = "${WORKSPACE}/pw-browsers"

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }
  
  before('tests') {
    sh "rm -rf smoke-output functional-output allure-results allure-results-smoke"
    sh "npx playwright install chromium --with-deps"
  }

  before('functionalTests') {
    env.FUNCTIONAL_TESTS_COMMAND = "test:functional"
  }

  afterSuccess('functionalTests') {
    yarnBuilder.yarn('test:a11y')
  }

  afterAlways('smokeTest') {
    junit testResults: 'smoke-output/smoke--test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/**', allowEmptyArchive: true
    
    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results-smoke']]
    ])
  }

  afterAlways('functionalTests') {
     junit testResults: 'functional-output/functional-test-results.xml', allowEmptyResults: true
     
     allure([
        includeProperties: false,
        jdk: '',
        properties: [],
        reportBuildPolicy: 'ALWAYS',
        results: [[path: 'allure-results']] 
     ])
     
     archiveArtifacts artifacts: 'functional-output/**', allowEmptyArchive: true
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.JENKINS_BRANCH = "master"
  }

  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}