#!groovy

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET")
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  env.UNIT_TESTS_COMMAND = "yarn test:unit && yarn test:coverage && yarn lint && yarn test:routes && yarn test:a11y"
  
  loadVaultSecrets(secrets) 

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  before('tests') {
    sh 'rm -rf smoke-output functional-output allure-results* test-results'
  }

  // --- FUNCTIONAL & ACCESSIBILITY TESTS ----
  before('functionalTest') {
    // create the directories
    sh 'mkdir -p functional-output allure-results-functional allure-results-a11y'
    
    // simple relative path for the browsers
    env.PLAYWRIGHT_BROWSERS_PATH = "pw-browsers"
    
    // Install and Run Functional and Accessibility tests together to ensure they run in the same container instance
    env.FUNCTIONAL_TESTS_CMD = """
      export PLAYWRIGHT_BROWSERS_PATH=$(pwd)/pw-browsers
      
      echo "--- Installing Browsers to Local Folder ---"
      yarn playwright install chromium chromium-headless-shell --with-deps

      echo "--- Running Functional Tests ---"
      REPORT_NAME=functional JUNIT_REPORT_NAME=junit-functional.xml ALLURE_RESULTS_DIR=allure-results-functional yarn test:functional; func_exit=\$?;
      
      echo "--- Running Accessibility Tests ---"
      REPORT_NAME=accessibility JUNIT_REPORT_NAME=junit-a11y.xml ALLURE_RESULTS_DIR=allure-results-a11y yarn test:playwright:a11y || true;
      
      exit \$func_exit
    """
  }

  afterAlways('functionalTest') {
      echo "Processing Functional and Accessibility Reports..."
      
      sh '''
            # Clean up old final report names
            rm -rf functional-output/functional-html-report functional-output/a11y-html-report

            # Move and rename functional report
            if [ -d "functional-output/playwright-functional-test-report" ]; then
              mv -v functional-output/playwright-functional-test-report functional-output/functional-html-report
              mv functional-output/functional-html-report/index.html functional-output/functional-html-report/functional-report.html
            fi

            # Move and rename a11y report
            if [ -d "functional-output/playwright-accessibility-test-report" ]; then
              mv -v functional-output/playwright-accessibility-test-report functional-output/a11y-html-report
              mv functional-output/a11y-html-report/index.html functional-output/a11y-html-report/a11y-report.html
            fi
          '''

    // Aggregate Junit XMLs for the Jenkins Test Result Trend graph
    junit testResults: 'functional-output/junit-*.xml', allowEmptyResults: true
    
    // Consolidate Allure into a single unified report view
    allure([
        includeProperties: false,
        jdk: '',
        properties: [],
        reportBuildPolicy: 'ALWAYS',
        results: [
          [path: 'allure-results-functional'], 
          [path: 'allure-results-a11y']
        ]
    ])
    
    // Archive 
    archiveArtifacts artifacts: 'functional-output/**', allowEmptyArchive: true
  }

  afterAlways('smokeTest') {
    junit testResults: '**/smoke-output/*.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'smoke-output/**', allowEmptyArchive: true
    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results-smoke']]
    ])
  }

  enableSlackNotifications('#finrem-dev')
  enableAksStagingDeployment()
  disableLegacyDeployment()

  onMaster() {
    env.JENKINS_BRANCH = "master"
  }

  onPR() {
    env.JENKINS_BRANCH = "preview"
    env.ENABLE_FULL_FUNCTIONAL_TESTS = "true"
  }
}