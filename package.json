{
  "name": "finrem-citizen-ui",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "start": "NODE_ENV=production ts-node -r tsconfig-paths/register src/main/server.ts",
    "start:dev": "nodemon --config nodemon.json",
    "start:mock-case-api": "ts-node -r dotenv/config src/main/mock-case-api/server.ts",
    "lint": "eslint .",
    "lint-staged": "lint-staged",
    "lint:fix": "eslint . --fix",
    "build": "yarn webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production yarn webpack --mode production --config webpack.config.js",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:api": "jest --roots src/test/api --testRegex='.*\\.test\\.ts$'",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:a11y": "echo 'placeholder'",
    "test:playwright:a11y:chrome": "TEST_RESULTS_DIR=a11y-output PLAYWRIGHT_HTML_OUTPUT_DIR=a11y-output/axe-report PLAYWRIGHT_HTML_OPEN=never playwright test --config playwright.config.mts --project chromium --grep @a11y --reporter=html",
    "test:playwright:a11y:all-browsers": "sh -c 'TEST_RESULTS_DIR=a11y-output PLAYWRIGHT_HTML_OUTPUT_DIR=a11y-output/axe-report PLAYWRIGHT_HTML_OPEN=never playwright test --config playwright.config.mts --grep @a11y --reporter=html; code=$?; yarn playwright show-report a11y-output/axe-report; exit $code'",
    "test:smoke": "NODE_TLS_REJECT_UNAUTHORIZED=0 jest --config jest.smoke.config.js",
    "test:functional": "yarn playwright install --with-deps && playwright test --config playwright.config.mts --project chromium --retries=2",
    "test:fullfunctional": "yarn test:functional",
    "test:functional:pr": "yarn playwright install --with-deps && playwright test --config playwright.config.mts --project chromium --grep @PR",
    "test:functional:headed:slowmo": "PWDEBUG=1 PLAYWRIGHT_SLOWMO_MS=250 playwright test --config playwright.config.mts --project chromium --headed --workers=1",
    "test:functional:allBrowsers:ui": "playwright test --ui",
    "setup:manual-test": "yarn setup:manual-test:mock",
    "setup:manual-test:mock": "RUNNING_ENV=local MOCK_ACCESS_CODES=true jest -c jest.manual.config.js --runTestsByPath src/test/unit/scripts/setupManualTest.manual.test.ts --runInBand --detectOpenHandles",
    "cichecks": "yarn build && yarn lint && yarn test && yarn test:routes && yarn test:api && yarn test:coverage",
    "qacichecks": "yarn build && yarn lint && yarn test && yarn test:routes && yarn test:api && yarn test:coverage && yarn test:functional",
    "prepare": "husky install"
  },
  "dependencies": {
    "@hmcts/info-provider": "1.4.0",
    "@hmcts/nodejs-healthcheck": "1.8.6",
    "@hmcts/nodejs-logging": "4.0.4",
    "@hmcts/properties-volume": "1.4.0",
    "@types/body-parser": "1.19.6",
    "@types/connect-redis": "^0.0.23",
    "@types/cookie-parser": "1.4.10",
    "@types/es6-promisify": "6.0.4",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/lodash": "4.17.24",
    "@types/multer": "^2.1.0",
    "@types/nunjucks": "3.2.6",
    "accessible-autocomplete": "^3.0.1",
    "applicationinsights": "^3.14.0",
    "axios": "1.17.0",
    "body-parser": "2.2.2",
    "config": "4.4.1",
    "connect-redis": "^8.1.0",
    "cookie-parser": "1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "1.19.0",
    "fs-extra": "^11.3.4",
    "glob": "13.0.6",
    "govuk-frontend": "^6.0.0",
    "helmet": "8.2.0",
    "ioredis": "^5.10.0",
    "jwt-decode": "4.0.0",
    "lodash": "4.18.1",
    "multer": "^2.1.1",
    "node-cache": "5.1.2",
    "nunjucks": "3.2.4",
    "openid-client": "^6.8.2",
    "otplib": "13.4.1",
    "proper-lockfile": "^4.1.2",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
