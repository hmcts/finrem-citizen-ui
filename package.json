    "if-env": "^1.0.4",
    "jest": "^30.0.0",
    "jest-allure2-reporter": "*",
    "jest-circus": "*",
    "jest-environment-jsdom": "^30.4.1",
    "jest-html-reporter": "4.4.0",
    "jest-junit": "17.0.0",
    "lint-staged": "17.0.7",
    "mini-css-extract-plugin": "2.10.2",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "sass": "1.100.0",
    "sass-loader": "17.0.0",
    "style-loader": "4.0.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "9.6.0",
