{
  "name": "finrem-citizen-ui",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "start": "NODE_ENV=production ts-node -r tsconfig-paths/register src/main/server.ts",
    "start:dev": "nodemon --config nodemon.json",
    "lint": "eslint .",
    "lint-staged": "lint-staged",
    "lint:fix": "eslint . --fix",
    "build": "yarn webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production yarn webpack --mode production --config webpack.config.js",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:a11y": "echo 'placeholder'",
    "test:playwright:a11y": "TEST_RESULTS_DIR=a11y-output PLAYWRIGHT_HTML_OUTPUT_DIR=a11y-output/axe-report PLAYWRIGHT_HTML_OPEN=never playwright test --config playwright.config.mts --project chromium --grep @a11y --reporter=html",
    "test:playwright:a11y:report": "sh -c 'yarn test:playwright:a11y; code=$?; yarn playwright show-report a11y-output/axe-report; exit $code'",
    "test:smoke": "NODE_TLS_REJECT_UNAUTHORIZED=0 jest --config jest.smoke.config.js",
    "test:functional": "npx playwright install --with-deps && playwright test --config playwright.config.mts --project chromium --grep @PR",
    "test:full-functional": "playwright test --config playwright.config.mts --retries=2",
    "test:fullfunctional:allBrowsers:ui": "playwright test --ui",
    "cichecks": "yarn build && yarn lint && yarn test && yarn test:routes",
    "qacichecks": "yarn build && yarn lint && yarn test && yarn test:routes && yarn test:functional",
    "prepare": "husky install"
  },
  "dependencies": {
    "@hmcts/info-provider": "1.4.0",
    "@hmcts/nodejs-healthcheck": "1.8.6",
    "@hmcts/nodejs-logging": "4.0.4",
    "@hmcts/properties-volume": "1.3.2",
    "@types/body-parser": "1.19.6",
    "@types/connect-redis": "^0.0.23",
    "@types/cookie-parser": "1.4.10",
    "@types/es6-promisify": "6.0.4",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/lodash": "4.17.24",
    "@types/nunjucks": "3.2.6",
    "@types/require-directory": "2.1.7",
    "accessible-autocomplete": "^3.0.1",
    "applicationinsights": "3.14.0",
    "axios": "1.14.0",
    "body-parser": "2.2.2",
    "config": "4.4.1",
    "connect-redis": "^7.1.1",
