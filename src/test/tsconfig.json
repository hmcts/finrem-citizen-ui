{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "../../",
    "lib": ["ESNext", "DOM"],
    "types": ["node", "@playwright/test", "jest", "express-session", "multer"],
    "baseUrl": "../../",
    "paths": {
      "router/*": ["src/main/router/*"],
      "routes/*": ["src/main/routes/*"],
      "@pom/*": ["src/test/functional/pom/*"],
      "@helpers/*": ["src/test/functional/utils/helpers/*"]
    }
  },
  "include": ["**/*.ts", "../../playwright.config.mts"],
  "exclude": []
}
