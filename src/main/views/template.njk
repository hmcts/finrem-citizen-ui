{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% extends "govuk/template.njk" %}

{% block head %}
  {% if googleTagManagerId %}
    <meta name="gtm-one-time" content="{{ cspNonce }}">
    <script nonce="{{ cspNonce }}">
      window.dataLayer = window.dataLayer || [];
      const userPreferenceCookie = document.cookie.match(new RegExp('(^| )' + 'cm-user-preferences' + '=([^;]+)'));

      if (userPreferenceCookie) {
        try {
          const cookiePreferences = JSON.parse(decodeURIComponent(userPreferenceCookie[2]));
          window.dataLayer.push({ event: 'Cookie Preferences', cookiePreferences });
        } catch (error) {
          window.dataLayer.push({ event: 'Cookie Preferences', cookiePreferences: {} });
        }
      }
    </script>
    <!-- Google Tag Manager -->
    <script nonce="{{ cspNonce }}">
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;var n=d.querySelector('[nonce]');
      n&&j.setAttribute('nonce',n.nonce||n.getAttribute('nonce'));f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','{{ googleTagManagerId }}');
    </script>
    <!-- End Google Tag Manager -->
  {% endif %}
  {% include "webpack/css.njk" %}
{% endblock %}

{% block header %}
  {{ govukHeader({
    homepageUrl: "/",
    containerClasses: "govuk-width-container"
  }) }}
  {{ govukServiceNavigation({
    serviceName: "Dividing your money and property",
    serviceUrl: "/",
    navigation: [
      {
        href: "/logout",
        text: "Sign out"
      }
    ]
  }) }}
{% endblock %}

{% block beforeContent %}
  {% set feedbackLinkHtml %}This is a new service – your <a class="govuk-link" href="{{ feedbackSurveyUrl }}" target="_blank" rel="noopener noreferrer" aria-label="provide feedback on this service (opens in a new tab)">feedback</a> will help us to improve it.{% endset %}
  {{ govukPhaseBanner({
    tag: {
      text: "Beta"
    },
    html: feedbackLinkHtml
  }) }}
{% endblock %}

{% block bodyStart %}
  {% if googleTagManagerId %}
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ googleTagManagerId }}" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
  {% endif %}
{% endblock %}

{% block bodyEnd %}
  {# Run JavaScript at end of the <body>, to avoid blocking the initial render. #}
  {% include "webpack/js.njk" %}
{% endblock %}
