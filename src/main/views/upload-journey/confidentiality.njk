{% extends "template.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if previousStep %}
        <a href="/upload-journey/{{ previousStep }}" class="govuk-back-link">Back</a>
      {% endif %}

      {% if errors and errors.acknowledgedConfidentiality %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#acknowledgedConfidentiality">{{ errors.acknowledgedConfidentiality }}</a></li>
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-xl">Confidentiality</h1>

      <p class="govuk-body">This is a placeholder page for the confidentiality statement.</p>

    </div>
  </div>
{% endblock %}
