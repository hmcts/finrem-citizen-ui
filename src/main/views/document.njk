{% extends "template.njk" %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <h1 class="govuk-heading-l">Documents</h1>

    <p class="govuk-body">
      Upload a document via the secure Document API.
    </p>

    {% if uploadedDocuments and uploadedDocuments.length %}
      <div class="govuk-notification-banner govuk-notification-banner--success" role="alert">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title">
            Success
          </h2>
        </div>
        <div class="govuk-notification-banner__content">
          <h3 class="govuk-notification-banner__heading">
            Document uploaded successfully
          </h3>

          <ul class="govuk-list govuk-list--bullet">
            {% for url in uploadedDocuments %}
              <li>
                <a
                  class="govuk-link"
                  href="{{ url }}"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {{ url }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endif %}

    <h2 class="govuk-heading-m">Upload document</h2>

    <form
      method="post"
      action="/documents/upload"
      enctype="multipart/form-data"
    >
      <div class="govuk-form-group">
        <label class="govuk-label" for="file">
          Choose a file to upload
        </label>

        <input
          class="govuk-file-upload"
          id="file"
          name="file"
          type="file"
          required
        >
      </div>

      <button
        type="submit"
        class="govuk-button"
        data-module="govuk-button"
      >
        Upload document
      </button>
    </form>

    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

  </div>
</div>
{% endblock %}