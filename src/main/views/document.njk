{% extends "template.njk" %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <h1 class="govuk-heading-l">Documents</h1>

    <p class="govuk-body">
      Upload a document and download it via the secure Document API.
    </p>

    <h2 class="govuk-heading-m">Upload document</h2>

    <form
      method="post"
      action="/documents/upload"
      enctype="multipart/form-data"
    >

      <div class="govuk-form-group">
        <label class="govuk-label" for="file">
          Choose a file to upload
        </label>

        <input
          class="govuk-file-upload"
          id="file"
          name="file"
          type="file"
          required
        >
      </div>

      <button
        type="submit"
        class="govuk-button"
        data-module="govuk-button"
      >
        Upload document
      </button>
    </form>

    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

    <h2 class="govuk-heading-m">Download document</h2>

    {% if uploadedDocumentId %}
      <p class="govuk-body">
        <a
          href="/documents/{{ uploadedDocumentId }}/download"
          class="govuk-link"
        >
          Download uploaded document
        </a>
      </p>
    {% else %}
      <p class="govuk-hint">
        Upload a document to enable download.
      </p>
    {% endif %}

  </div>
</div>
{% endblock %}
