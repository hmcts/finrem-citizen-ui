{% from "../macros/getting-help.njk" import gettingHelp %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/error-message/macro.njk" import govukErrorMessage %}

{% extends "template.njk" %}

{% block head %}
  {{ super() }}
  <meta name="gtm-one-time" content="{{globals.nonce}}">
  <!-- Google Tag Manager -->
  <script nonce='{{ globals.nonce }}'>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-N2TBV3X8');</script>
  <!-- End Google Tag Manager -->
{% endblock %}

{% block bodyStart %}
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N2TBV3X8"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if previousStep %}
        <a href="/upload/{{ previousStep }}" class="govuk-back-link govuk-!-margin-top-0 govuk-!-margin-bottom-6">Back</a>
      {% endif %}

      {% if errors and data.selectedDocumentTypes %}
        {% set errorList = [] %}
        {% for documentType in data.selectedDocumentTypes %}
          {% if errors[documentType.value] %}
            {% set errorList = (errorList.push({
              text: errors[documentType.value],
              href: "#file-upload-" + documentType.value
            }), errorList) %}
          {% endif %}
        {% endfor %}
        {% if errorList.length > 0 %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: errorList
          }) }}
        {% endif %}
      {% endif %}

      <h1 class="govuk-heading-l">Upload your documents</h1>

      <p class="govuk-body">
        Upload each of your documents in the corresponding section.
        You will be able to check what you have uploaded before you submit them to the court.
      </p>

      {% if data.selectedDocumentTypes and data.selectedDocumentTypes.length > 0 %}
        {% for documentType in data.selectedDocumentTypes %}
          <h2 class="govuk-heading-m govuk-!-margin-top-8">{{ documentType.label }}</h2>

         {% if shouldAutoRename(documentType.value) %}
  <p class="govuk-body">
    When you upload this document, it will automatically be renamed to <strong>{{ generateRenamedFilename(documentType.value, '', caseUserName, true) }}</strong>.
  </p>
{% endif %}

          {% set docTypeError = errors[documentType.value] if errors %}
          <div class="govuk-inset-text govuk-!-margin-top-4{% if docTypeError %} govuk-inset-text--error{% endif %}">
            <form method="post" action="/documents/upload?documentType={{ documentType.value }}&returnUrl=/upload/upload-documents" enctype="multipart/form-data" data-upload-form="{{ documentType.value }}">
              <input type="hidden" name="documentType" value="{{ documentType.value }}">
              <input type="hidden" name="returnUrl" value="/upload/upload-documents">

              {{ govukFileUpload({
                id: "file-upload-" + documentType.value,
                name: "file",
                label: {
                  text: "Upload a file",
                  classes: "govuk-label--s"
                },
                hint: {
                  text: "Files must be in jpg, png, pdf, docx or xlsx format."
                },
                errorMessage: {
                  text: docTypeError
                } if docTypeError,
                attributes: {
                  "aria-describedby": "file-upload-" + documentType.value + "-hint"
                }
              }) }}

              {{ govukButton({
                text: "Upload file",
                classes: "govuk-button--secondary govuk-!-margin-top-2",
                attributes: {
                  "data-upload-button": documentType.value,
                  "aria-label": "Upload file for " + documentType.label
                }
              }) }}
            </form>
          </div>

          <h3 class="govuk-heading-s govuk-!-margin-top-6">Uploaded files</h3>

          <div data-uploaded-files="{{ documentType.value }}">
            {% set uploadedFiles = data.uploadedFiles[documentType.value] if data.uploadedFiles %}

            {% if uploadedFiles and uploadedFiles.length > 0 %}
              <ul class="govuk-list">
                {% for file in uploadedFiles %}
                  <li class="govuk-!-margin-bottom-2">
                    <a href="{{ file.url }}" class="govuk-link" target="_blank" rel="noopener noreferrer">
                      {{ file.displayFilename }}
                    </a>
                    <a href="#"
                       class="govuk-link govuk-link--no-visited-state govuk-!-margin-left-2"
                       data-remove-file="{{ file.id }}"
                       data-document-type="{{ documentType.value }}"
                       aria-label="Remove {{ file.displayFilename }}">
                      Remove document
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="govuk-body govuk-hint">No files uploaded yet.</p>
            {% endif %}
          </div>

          {% if loop.index < data.selectedDocumentTypes.length %}
            <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
          {% endif %}
        {% endfor %}
      {% else %}
        <p class="govuk-body">No document types selected. Please go back and select the documents you want to upload.</p>
      {% endif %}

      <form method="post" class="govuk-!-margin-top-8">
        {{ govukButton({
          text: "Continue"
        }) }}
      </form>
    </div>

    <div class="govuk-grid-column-one-third">
      {{ gettingHelp(contactEmail) }}
    </div>
  </div>
{% endblock %}
