{% extends "template.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errors.step7Answer %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            {
              text: errors.step7Answer,
              href: "#step7Answer"
            }
          ]
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">Step 7 - Question</h1>
      
      <form method="POST" action="/journey/step7-question">
        {{ govukRadios({
          name: "step7Answer",
          fieldset: {
            legend: {
              text: "Do you want to continue?",
              classes: "govuk-fieldset__legend--m"
            }
          },
          items: [
            {
              value: "yes",
              text: "Yes",
              checked: values.step7Answer === "yes"
            },
            {
              value: "no",
              text: "No",
              checked: values.step7Answer === "no"
            }
          ],
          errorMessage: {
            text: errors.step7Answer
          } if errors.step7Answer
        }) }}

        {{ govukButton({
          text: "Continue"
        }) }}
      </form>
      
      {% if previousStep %}
        <p class="govuk-body">
          <a href="/journey/{{ previousStep }}" class="govuk-link">Back</a>
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}
