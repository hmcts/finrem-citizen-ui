#!groovy

properties([
  // Runs at 23:45  PM, Monday to Friday
  pipelineTriggers([cron('45 23 * * 1-5')]),
  parameters([
    string(name: 'URL_TO_TEST', defaultValue: 'https://finrem-citizen-ui.aat.platform.hmcts.net',
      description: 'The URL you want to run these tests against'),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def secrets = [
  'finrem-${env}': [
    secret("idam-secret" ,"OAUTH2_CLIENT_FINREM"),
    secret("finrem-idam-client-secret", "FINREM_IDAM_CLIENT_SECRET"),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

withNightlyPipeline(type, product, component) {
  // Sync Jenkins Parameter to the Env Var Playwright is looking for
  env.TEST_URL = params.URL_TO_TEST
  env.RUNNING_ENV = "aat"
  
  loadVaultSecrets(secrets)

  // TODO: Enable and implement when these tests are planned and written
  // For reference see: nfdiv-frontend application
  // enableCrossBrowserTest()
  // enablePerformanceTest()
  // enableMutationTest()


  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  before('fullFunctionalTest') {
    // Point to playwright command in package.json
    env.FULL_FUNCTIONAL_TESTS_COMMAND = "test:functional"
    
    // 2. Set the directory for the Playwright Config logic
    env.TEST_RESULTS_DIR = "functional-output"
    env.ALLURE_RESULTS_DIR = "allure-results"
    
    // 3. Install browser once
    sh 'npx playwright install chromium --with-deps'
  }

  // Set parallelism (20 is safe for AAT; 200 may cause IDAM rate-limiting)
  enableFullFunctionalTest(20)

  afterAlways('fullFunctionalTest') {
    junit testResults: 'functional-output/functional-test-results.xml', allowEmptyResults: true
    
    // Archive everything (Reports + Traces + Videos)
    archiveArtifacts artifacts: 'functional-output/**', allowEmptyArchive: true

    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results']]
    ])
  }

  afterSuccess('fullFunctionalTest') {
    sh 'npx playwright install chromium --with-deps'
    yarnBuilder.yarn('test:a11y')
  }

  enableSlackNotifications('#finrem-dev')
}