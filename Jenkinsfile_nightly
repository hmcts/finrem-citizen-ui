#!groovy

properties([
  pipelineTriggers([cron('00 21 * * 1-5')]),
  parameters([
    string(name: 'URL_TO_TEST', defaultValue: 'https://finrem-citizen-ui.aat.platform.hmcts.net',
      description: 'The URL you want to run these tests against'),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET"),
  ]
]

    static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

withNightlyPipeline(type, product, component) {
  env.TEST_URL = params.URL_TO_TEST
  loadVaultSecrets(secrets)

  // TODO: Enable and implement when these tests are planned and written
  //  For reference see: nfdiv-frontend application
  //enableCrossBrowserTest()
  //enablePerformanceTest()
  //enableMutationTest()

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }


  // The library will handle running these based on the variables below
  before('fullFunctionalTest') {
    env.FULL_FUNCTIONAL_TESTS_COMMAND = "test:full-functional:report"
    env.A11Y_TESTS_COMMAND = "test:a11y:report"
    sh 'npx playwright install chromium --with-deps'
  }

  // This enables the built-in stage for functional tests
  enableFullFunctionalTest(200)

  afterAlways('fullFunctionalTest') {
    junit testResults: 'functional-output/test-results.xml', allowEmptyResults: true
    junit testResults: 'a11y-output/test-results.xml', allowEmptyResults: true
    archiveArtifacts artifacts: 'functional-output/playwright-functional-test-report.html,functional-output/**,a11y-output/playwright-accessibility-test-report.html,a11y-output/**', allowEmptyArchive: true
    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [
        [path: 'functional-output/allure-results'],
        [path: 'a11y-output/allure-results']
      ]
    ])
  }

  enableSlackNotifications('#finrem-dev')
}