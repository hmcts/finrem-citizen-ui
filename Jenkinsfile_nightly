#!groovy

properties([
  pipelineTriggers([cron('45 21 * * 1-5')]),
  parameters([
    string(name: 'URL_TO_TEST', defaultValue: 'https://finrem-citizen-ui.aat.platform.hmcts.net',
      description: 'The URL you want to run these tests against'),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET"),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

withNightlyPipeline(type, product, component) {
  env.TEST_URL = params.URL_TO_TEST
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  // --- FULL FUNCTIONAL TESTS ---
  before('fullFunctionalTest') {
    sh 'rm -rf functional-output allure-results allure-results-a11y-nightly'
    sh 'mkdir -p functional-output allure-results allure-results-a11y-nightly'
    
    env.TEST_RESULTS_DIR = "functional-output"
    env.REPORT_NAME = "full-functional"
    env.FULL_FUNCTIONAL_TESTS_COMMAND = """
      echo "--- Installing Playwright Browsers in Nightly Container ---"
      yarn playwright install chromium chromium-headless-shell --with-deps
      
      echo "--- Running Full Functional Tests ---"
      yarn test:full-functional
    """
  }

  enableFullFunctionalTest(200)

  // --- ACCESSIBILITY TESTS ---
  afterAlways('fullFunctionalTest') {
    sh """
      yarn playwright install chromium chromium-headless-shell --with-deps
      REPORT_NAME=accessibility-nightly TEST_RESULTS_DIR=functional-output ALLURE_RESULTS_DIR=allure-results-a11y-nightly yarn test:playwright:a11y || true
    """

    sh '''
      echo "Processing Nightly report folders..."
      
      # Clean up old final report names
      rm -rf functional-output/full-functional-html-report functional-output/a11y-nightly-html-report

      # Move and rename Full Functional report folder
      if [ -d "functional-output/playwright-full-functional-test-report" ]; then
        mv -v functional-output/playwright-full-functional-test-report functional-output/full-functional-html-report
        mv functional-output/full-functional-html-report/index.html functional-output/full-functional-html-report/full-functional-report.html
      fi

      # Move and rename A11y Nightly report folder
      if [ -d "functional-output/playwright-accessibility-nightly-test-report" ]; then
        mv -v functional-output/playwright-accessibility-nightly-test-report functional-output/a11y-nightly-html-report
        mv functional-output/a11y-nightly-html-report/index.html functional-output/a11y-nightly-html-report/a11y-nightly-report.html
      fi
    '''

    // Aggregate JUnit XMLs
    junit testResults: 'functional-output/*.xml', allowEmptyResults: true

    // Consolidate Allure
    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [
        [path: 'allure-results'], 
        [path: 'allure-results-a11y-nightly']
      ]
    ])

    // Archive all outputs
    archiveArtifacts artifacts: 'functional-output/**', allowEmptyArchive: true
  }

  enableSlackNotifications('#finrem-dev')
}