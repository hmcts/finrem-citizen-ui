#!groovy

properties([
  pipelineTriggers([cron('45 21 * * 1-5')]),
  parameters([
    string(name: 'URL_TO_TEST', defaultValue: 'https://finrem-citizen-ui.aat.platform.hmcts.net',
      description: 'The URL you want to run these tests against'),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "finrem"
def component = "citizen-ui"

def secrets = [
  'finrem-${env}': [
    secret("finrem-citizen-s2s-client-secret", "SERVICE_AUTH_SECRET"),
    secret("finrem-citizen-ui-idam-client-secret", "FINREM_CITIZEN_UI_IDAM_CLIENT_SECRET"),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

withNightlyPipeline(type, product, component) {
  env.TEST_URL = params.URL_TO_TEST
  loadVaultSecrets(secrets)

  afterSuccess('build') {
    yarnBuilder.yarn('build')
  }

  // --- FULL FUNCTIONAL TESTS ---
  before('fullFunctionalTest') {
    sh 'yarn playwright install chromium --with-deps'
    sh 'rm -rf functional-output allure-results allure-results-a11y-nightly'
    sh 'mkdir -p functional-output allure-results allure-results-a11y-nightly'
    
    // Set the output directory for the main functional run
    env.TEST_RESULTS_DIR = "functional-output"
    env.REPORT_NAME = "full-functional"
    env.FULL_FUNCTIONAL_TESTS_COMMAND = "yarn test:full-functional"
  }

  enableFullFunctionalTest(200)

  // --- ACCESSIBILITY TESTS ---
  afterAlways('fullFunctionalTest') {
    // Run A11y tests, ensuring variables match the folder naming logic
    sh "REPORT_NAME=accessibility-nightly TEST_RESULTS_DIR=functional-output ALLURE_RESULTS_DIR=allure-results-a11y-nightly yarn test:playwright:a11y || true"

    // Renaming logic updated to match the folder names generated by playwright.config.mts
    sh '''
      echo "Processing Nightly report artifacts..."
      
      # Copy Full Functional Report
      if [ -f functional-output/playwright-full-functional-test-report/index.html ]; then
        cp functional-output/playwright-full-functional-test-report/index.html functional-output/playwright-full-functional-report.html
      fi

      # Copy Accessibility Nightly Report
      if [ -f functional-output/playwright-accessibility-nightly-test-report/index.html ]; then
        cp functional-output/playwright-accessibility-nightly-test-report/index.html functional-output/playwright-accessibility-nightly-report.html
      fi
    '''

    // Uses wildcard to pick up both full-functional and accessibility xml files
    junit testResults: 'functional-output/*.xml', allowEmptyResults: true

    allure([
      includeProperties: false,
      jdk: '',
      properties: [],
      reportBuildPolicy: 'ALWAYS',
      results: [[path: 'allure-results'], [path: 'allure-results-a11y-nightly']]
    ])

    archiveArtifacts artifacts: 'functional-output/**, allure-results-a11y-nightly/**', allowEmptyArchive: true
  }

  enableSlackNotifications('#finrem-dev')
}