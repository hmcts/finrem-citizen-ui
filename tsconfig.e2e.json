// used for Playwright tests, separate from the main tsconfig to avoid conflicts with test-specific types and settings
// src/test
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "router/*": ["src/main/router/*"],
      "routes/*": ["src/main/routes/*"],
      // test-specific paths
      "@pom/*": ["src/test/functional/pom/*"],
      "@helpers/*": ["src/test/functional/utils/helpers/*"]
    }
  },
  "include": ["src/test/functional/**/*.ts", "src/test/a11y/**/*.ts", "playwright.config.ts"]
}
