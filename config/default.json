{
  "useCSRFProtection": true,
  "appInsights": {
    "instrumentationKey": false
  },
  "security": {
    "referrerPolicy": "same-origin",
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true
    }
  },
  "services": {
    "idam": {
      "systemUsername": "dummy_user",
      "systemPassword": "",
      "clientID": "finrem-citizen-ui",
      "clientSecret": "NEED TO INSERT SECRET",
      "authorizationURL": "https://hmcts-access.aat.platform.hmcts.net/login",
      "tokenURL": "https://idam-api.aat.platform.hmcts.net/o/token",
      "caching": false
    },
    "authProvider": {
      "url": "http://rpe-service-auth-provider-aat.service.core-compute-aat.internal",
      "microservice": "finrem_citizen_ui",
      "secret": "NEED TO INSERT SECRET"
    },
    "case": {
      "url": "https://ccd-data-store-api-finrem-ccd-definitions-pr-3089.preview.platform.hmcts.net"
    }
  },
  "oidc": {
    "issuer": "https://hmcts-access.aat.platform.hmcts.net/o",
    "clientId": "finrem-citizen-ui",
    "callbackUrl": "http://localhost:3100/oauth2/callback",
    "scope": "openid profile roles"
  },
  "session": {
    "cookieName": "finrem_session",
    "prefix": "finrem-session",
    "ttlInSeconds": 5400
  },
  "use-ssl": false,
  "features": {
    "redis": "false"
  },
  "secrets": {
    "finrem": {
      "finrem-citizen-ui-idam-client-secret": "AAAAAAAAAAAA",
      "session-secret": "finrem-local-dev-secret",
      "redis-connection-string": "redis://localhost:6379"
    }
  }
}
