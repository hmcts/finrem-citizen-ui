{
  "useCSRFProtection": true,
  "appInsights": {
    "connectionString": false
  },
  "security": {
    "referrerPolicy": "same-origin",
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true
    }
  },
  "services": {
    "idam": {
      "systemUsername": "dummy_user",
      "systemPassword": "",
      "clientID": "finrem-citizen-ui",
      "clientSecret": "NEED TO INSERT SECRET",
      "authorizationURL": "https://hmcts-access.aat.platform.hmcts.net/login",
      "tokenURL": "https://idam-api.aat.platform.hmcts.net/o/token",
      "caching": false
    },
    "authProvider": {
      "url": "http://rpe-service-auth-provider-aat.service.core-compute-aat.internal",
      "microservice": "finrem_citizen_ui",
      "secret": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
    },
    "case": {
      "url": "http://ccd-data-store-api-aat.service.core-compute-aat.internal"
    },
    "caseDocumentManagement": {
      "url": "http://ccd-case-document-am-api-aat.service.core-compute-aat.internal"
    },
    "orchestrationService": {
      "url": "http://finrem-cos-aat.service.core-compute-aat.internal"
    },
    "documentToPdfService": {
      "url": "http://dg-docassembly-aat.service.core-compute-aat.internal"
    }
  },
  "oidc": {
    "issuer": "https://hmcts-access.aat.platform.hmcts.net/o",
    "clientId": "finrem-citizen-ui",
    "callbackUrl": "http://localhost:3100/oauth2/callback",
    "scope": "openid profile roles"
  },
  "session": {
    "cookieName": "finrem_session",
    "prefix": "finrem-session",
    "store": "in-memory",
    "ttlInSeconds": 5400
  },
  "use-ssl": false,
  "secrets": {
    "finrem": {
      "finrem-citizen-ui-idam-client-secret": "AAAAAAAAAAAA",
      "session-secret": "finrem-local-dev-secret",
      "finrem-citizen-ui-redis-connection-string": "redis://localhost:6379",
      "GOV-UK-NOTIFICATION-KEY": "GOVUK_NOTIFY_API_KEY",
      "DOCUMENT-UPLOAD-EMAIL-TEMPLATE-ID": "FINREM_CITIZEN_UI_TEMPLATE_ID"
    }
  },
  "rateLimitWindowMs": 900000

}
