{
  "useCSRFProtection": true,
  "appInsights": {
    "instrumentationKey": false
  },
  "security": {
    "referrerPolicy": "same-origin",
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true
    }
  },
  "session": {
    "secret": "change-this-secret-in-production"
  },
  "services": {
    "case": {
      "url": "http://localhost:9000/citizen",
      "timeout": 10000
    }
  }
}
