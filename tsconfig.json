// Main TypeScript configuration for the backend code, excluding tests to prevent type conflicts and ensure clean separation of concerns
// / src/main
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "router/*": ["src/main/router/*"],
      "routes/*": ["src/main/routes/*"]
    }
  },
  "include": ["src/main/**/*.ts"], // 🎯 Target only backend source
  "exclude": ["node_modules", "src/test/**/*"] // 🛡️ Explicitly ignore tests
}
