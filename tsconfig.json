// Main TypeScript configuration for the backend code, excluding tests to prevent type conflicts and ensure clean separation of concerns
// / src/main
{
  "compilerOptions": {
    "outDir": "./src/",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": false,
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "baseUrl": "src/main",
    "paths": {
      "router/*": ["router/*"],
      "routes/*": ["routes/*"]
    }
  },
  "include": ["src/main/**/*"],
  "exclude": ["**/*.test.ts", "**/codecept.conf.ts", "**/__mocks__/*"],
  "ts-node": {
    "files": true
  }
}
