{
  "compilerOptions": {
    "outDir": "./src/",
    "rootDir": "src/main",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": false,
    "noUnusedLocals": true,
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test", "jest"],
    "lib": ["es2020", "dom", "dom.iterable"],
    "paths": {
      "app/*": ["./src/main/app/*"],
      "router/*": ["./src/main/router/*"],
      "routes/*": ["./src/main/routes/*"]
    }
  },
  "include": ["src/main/**/*"],
  "exclude": ["**/*.test.ts", "**/codecept.conf.ts", "**/__mocks__/*"],
  "ts-node": {
    "files": true
  }
}
