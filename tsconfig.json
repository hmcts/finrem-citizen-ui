{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "allowJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "router/*": ["src/main/router/*"],
      "routes/*": ["src/main/routes/*"],
      "@pom/*": ["src/test/functional/pom/*"],
      "@helpers/*": ["src/test/functional/utils/helpers/*"]
    }
  },
  "include": ["src/**/*.ts", "playwright.config.mts"]
}
