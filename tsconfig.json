{
  "compilerOptions": {
    "target": "ES2022", // Modern JS for Node 22
    "module": "CommonJS", // Matches standard HMCTS patterns
    "moduleResolution": "node",
    "strict": true,
    "allowJs": true, // Changed to true for better flexibility
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "router/*": ["src/main/router/*"],
      "routes/*": ["src/main/routes/*"]
    },
    "types": ["node", "@playwright/test"]
  },
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
